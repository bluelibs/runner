{
  "name": "ask-runner-example",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "node ./node_modules/tsx/dist/cli.cjs watch src/index.ts",
    "start": "node --enable-source-maps ./node_modules/tsx/dist/cli.cjs src/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "./node_modules/jest/bin/jest.js --runInBand",
    "qa": "npm run build && npm run test"
  },
  "dependencies": {
    "@bluelibs/runner": "file:../..",
    "express": "^5.2.1",
    "openai": "^5.15.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.3",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
