{
  "name": "ask-runner-example",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "node --watch-path=src --watch-path=package.json --watch-path=tsconfig.json --watch-preserve-output --import tsx ./src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "jest --runInBand",
    "qa": "npm run build && npm run test"
  },
  "dependencies": {
    "@bluelibs/runner": "file:../..",
    "dompurify": "^3.3.2",
    "express": "^5.2.1",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.4",
    "mermaid": "^11.13.0",
    "openai": "^5.15.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.3",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
